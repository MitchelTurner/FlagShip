# SQLite database location (relative to the prisma/ directory).
DATABASE_URL="file:./dev.db"

# Password required to access the admin upload area (/admin).
# Change this to a strong secret before deploying.
ADMIN_PASSWORD="changeme"

# GitHub account whose public repositories power the "Live work" portfolio.
# Resolution order: admin DB setting → this env var → github.config.json (committed).
GITHUB_USERNAME="MitchelTurner"

# Contact form email delivery (via Resend — https://resend.com).
# Without RESEND_API_KEY the form still works but falls back to a mailto link.
RESEND_API_KEY=""
# Inbox that receives contact submissions.
CONTACT_TO_EMAIL="info@mitchelturner.dev"
# Verified sender address (the domain must be verified in Resend).
CONTACT_FROM_EMAIL="Mitchel Turner <contact@mitchelturner.dev>"

# GitHub personal access token (classic or fine-grained, read-only).
# Strongly recommended: raises the API rate limit from 60 to 5,000 req/hr.
# Deployment status is fetched per repo, so without a token only the first
# ~12 repos get deployment badges (to stay under the unauthenticated limit) —
# set a token to show deployments for every repo. A token with public repo
# read access is enough.
GITHUB_TOKEN=""
